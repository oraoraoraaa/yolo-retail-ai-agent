# Copy to `.env` and adjust for your setup. All variables are optional;
# the backend runs with graceful fallbacks when they are unset.

# --- HTTP / CORS ---
# Comma-separated list of allowed frontend origins.
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Local vision (model-local) ---
# All image/video inference is performed by model-local using local weight
# files. Start it with: `cd model-local && uv run stream_server.py`
LOCAL_VISION_BASE_URL=http://127.0.0.1:8001
# Path to local ONNX (or YOLO) weights. Relative paths resolve from repo root.
LOCAL_VISION_MODEL=train/export/gap-product-chinese-yolo11n.onnx
LOCAL_VISION_TIMEOUT=60

# --- LLM agent (OpenAI-compatible) ---
# When OPENAI_API_KEY is empty the chat endpoint replies with a deterministic
# mock so the frontend stays usable without any external service.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Temporal debounce (false-positive suppression) ---
# A finding (e.g. a gap facing) must be observed in at least
# DEBOUNCE_MIN_OBSERVATIONS separate audits inside the trailing
# DEBOUNCE_WINDOW_SECONDS before it may open a ticket. This filters transient
# false positives — a customer walking past a shelf reads as a gap for a single
# snapshot, but that observation never repeats, so no ticket is opened.
# Set DEBOUNCE_MIN_OBSERVATIONS=1 to disable debounce (open on first sighting).
DEBOUNCE_MIN_OBSERVATIONS=2
DEBOUNCE_WINDOW_SECONDS=180
# Busy-store persistence gate: a confirmed finding must also SPAN at least this
# many wall-clock seconds, not merely appear in enough rapid-fire audits. A
# customer choosing/picking items can briefly reveal a clean gap between two
# quick audits, but does not linger at the same facing for a minute-plus, so
# requiring the gap to persist across real time filters slow walkers/lingerers
# the median clean plate alone can't clear. Latency is not prioritized (a
# ~2-minute alarm is acceptable); a false alarm is not. Set 0 to require only
# the observation count.
DEBOUNCE_MIN_SPAN_SECONDS=90
# Observation rows older than this are pruned on each write to keep the table small.
DEBOUNCE_RETENTION_SECONDS=1800

# --- Upload / payload size limits ---
# Raw image bytes (multipart uploads and decoded base64). Default 10 MiB.
MAX_UPLOAD_BYTES=10485760
# Max images accepted on a single chat multipart request.
MAX_CHAT_IMAGES=4
# Max length of an imageBase64 string on analyze-detections (≈10 MiB raw).
MAX_BASE64_CHARS=14680064

# --- Persistence (SQLite default; Postgres for multi-user store deploy) ---
# Leave empty for local SQLite at backend/data/retail.db
# Examples:
#   DATABASE_URL=sqlite:///./data/retail.db
#   DATABASE_URL=postgresql://user:pass@localhost:5432/yolo_retail
DATABASE_URL=
# Optional overrides (defaults: backend/data and backend/data/media)
# DATA_DIR=./data
# MEDIA_DIR=./data/media

# --- Auth (JWT staff login) ---
# Keep false for local demos. Set true for store / multi-user deployment.
# Three account tiers exist: owner (full control incl. account management),
# admin (change everything except accounts; accounts view-only), and staff
# (chat + view cameras only, no changes anywhere).
AUTH_ENABLED=false
# REQUIRED in production when AUTH_ENABLED=true — use a long random string.
AUTH_SECRET=dev-only-change-me-in-production
AUTH_TOKEN_TTL_HOURS=720
# Bootstrap account created as the top-tier OWNER when the users table is empty.
# The owner is the only role that can manage other accounts; create admin/staff
# users from the in-app Accounts panel after first login. (Older admin-only
# deploys are auto-upgraded: if no owner exists, the seed account is promoted.)
AUTH_ADMIN_USERNAME=owner
AUTH_ADMIN_PASSWORD=owner

# Copy to `.env` and adjust for your setup. All variables are optional;
# the backend runs with graceful fallbacks when they are unset.

# --- HTTP / CORS ---
# Comma-separated list of allowed frontend origins.
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- YOLO gap-detection ---
# Path to trained weights. Relative paths resolve from the repo root.
# When the file is missing (or ultralytics is not installed) the audit
# endpoint returns an informative placeholder instead of failing.
YOLO_WEIGHTS_PATH=artifacts/gap-detection/train/weights/best.pt
YOLO_CONF=0.25
YOLO_IOU=0.7
YOLO_IMGSZ=640

# --- LLM agent (OpenAI-compatible) ---
# When OPENAI_API_KEY is empty the chat endpoint replies with a deterministic
# mock so the frontend stays usable without any external service.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

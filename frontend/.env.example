# Leave empty to use local API stubs for chat/database (offline UI work).
# When set, the frontend calls this origin for agent chat, database, and
# optional agent-side audit analysis.
# Example: http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# Local vision service (model-local/stream_server.py) — required for stream
# and shelf-image detection. Uses local weight files only.
# Example: http://localhost:8001
VITE_STREAM_BASE_URL=http://localhost:8001

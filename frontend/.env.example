# Leave empty to use Vite's /api proxy (recommended for LAN / phone testing —
# browser stays same-origin with the UI, so CORS never runs).
# When set to an absolute origin, the browser talks to the backend directly and
# APP_CORS_ORIGINS / the private-LAN CORS regex must allow the UI origin.
# Example: http://localhost:8000
VITE_API_BASE_URL=

# Local vision service (model-local/stream_server.py) — required for stream
# and shelf-image detection. Uses local weight files only.
# Example: http://localhost:8001
VITE_STREAM_BASE_URL=http://localhost:8001
